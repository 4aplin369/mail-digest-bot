YANDEX_EMAIL=your-login@yandex.ru
YANDEX_APP_PASSWORD=your-yandex-app-password
YANDEX_IMAP_HOST=imap.yandex.ru
YANDEX_IMAP_PORT=993
YANDEX_MAILBOX=INBOX
YANDEX_TRASH_MAILBOX=Trash

TELEGRAM_BOT_TOKEN=123456789:telegram-bot-token
TELEGRAM_CHAT_ID=123456789

LOOKBACK_HOURS=30
MAX_MESSAGES=80
UNREAD_ONLY=true
DAILY_DIGEST_TIME=09:00
DAILY_DIGEST_TIMEZONE=Europe/Moscow

# Optional: comma-separated extra keywords. If empty, the built-in list is used.
IMPORTANT_KEYWORDS=

# Used only with: python mail_digest_bot.py --once
# Set to true to print the one-time digest instead of sending it to Telegram.
DRY_RUN=false
